{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "guide",
        "compare",
        "shopping",
        "faq"
      ]
    },
    "platforms": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "lastUpdated": {
      "type": "string"
    },
    "readingTime": {
      "type": "string"
    },
    "disclosureRequired": {
      "default": true,
      "type": "boolean"
    },
    "officialReminderRequired": {
      "default": true,
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "category",
    "lastUpdated"
  ]
}