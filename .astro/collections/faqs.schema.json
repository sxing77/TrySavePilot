{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "basic",
        "tracking",
        "payout",
        "safety",
        "disclosure"
      ]
    },
    "question": {
      "type": "string"
    },
    "answer": {
      "type": "string"
    },
    "relatedArticleSlug": {
      "type": "string"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "category",
    "question",
    "answer"
  ]
}