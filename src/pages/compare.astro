---
import BaseLayout from '../layouts/BaseLayout.astro';
import DisclosureBox from '../components/DisclosureBox.astro';
import { getCollection } from 'astro:content';

const platforms = await getCollection('platforms');

const criteria = [
  { label: '适合地区', key: 'region' },
  { label: '核心定位', key: 'positioning' },
  { label: '当前奖励', key: 'currentBonus' },
  { label: '提现方式', key: 'payoutMethods' },
  { label: '最适合', key: 'bestFor' },
  { label: '不适合', key: 'notFor' }
];
---

<BaseLayout title="返利平台对比">
  <section class="py-12 bg-gray-50 border-b">
    <div class="container mx-auto px-4 max-w-6xl">
      <h1 class="text-3xl font-extrabold text-gray-900 mb-4 text-center">
        主流返利平台全方位对比
      </h1>
      <p class="text-gray-600 text-center max-w-2xl mx-auto">
        不用再纠结选哪家。这里整理了 Rakuten、TopCashback 和 Honey 的核心差异，帮助你按自己的使用习惯快速决定。
      </p>
    </div>
  </section>

  <div class="container mx-auto px-4 py-12 max-w-6xl">
    <DisclosureBox type="standard" />

    <div class="hidden md:block overflow-x-auto bg-white rounded-xl border border-gray-200 shadow-sm">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="bg-gray-50 border-b border-gray-200">
            <th class="p-6 text-sm font-semibold text-gray-500 w-1/4">对比维度</th>
            {platforms.map((platform) => (
              <th class="p-6 text-lg font-bold text-blue-600 border-l border-gray-100">
                {platform.data.name}
              </th>
            ))}
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          {criteria.map((item) => (
            <tr>
              <td class="p-6 text-sm font-medium text-gray-700 bg-gray-50/30">
                {item.label}
              </td>
              {platforms.map((platform) => (
                <td class="p-6 text-sm text-gray-600 border-l border-gray-100">
                  {Array.isArray(platform.data[item.key]) ? (
                    <ul class="list-disc list-inside space-y-1">
                      {platform.data[item.key].map((value) => <li>{value}</li>)}
                    </ul>
                  ) : (
                    platform.data[item.key]
                  )}
                </td>
              ))}
            </tr>
          ))}
          <tr class="bg-gray-50/50">
            <td class="p-6"></td>
            {platforms.map((platform) => (
              <td class="p-6 border-l border-gray-100">
                <a
                  href={`/guides/${platform.data.slug}`}
                  class="block text-center bg-blue-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-blue-700"
                >
                  查看 {platform.data.name} 教程
                </a>
              </td>
            ))}
          </tr>
        </tbody>
      </table>
    </div>

    <div class="md:hidden space-y-8">
      {platforms.map((platform) => (
        <div class="border border-gray-200 rounded-xl overflow-hidden shadow-sm">
          <div class="bg-blue-600 p-4 text-white">
            <h3 class="text-xl font-bold">{platform.data.name}</h3>
            <p class="text-blue-100 text-xs mt-1">{platform.data.positioning}</p>
          </div>
          <div class="p-4 space-y-4 bg-white">
            {criteria.slice(2).map((item) => (
              <div>
                <span class="text-xs font-bold text-gray-400 uppercase tracking-wider">
                  {item.label}
                </span>
                <div class="text-sm text-gray-700 mt-1">
                  {Array.isArray(platform.data[item.key])
                    ? platform.data[item.key].join('、')
                    : platform.data[item.key]}
                </div>
              </div>
            ))}
            <a
              href={`/guides/${platform.data.slug}`}
              class="block text-center border border-blue-600 text-blue-600 py-3 rounded-lg font-medium"
            >
              查看完整使用教程
            </a>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 bg-yellow-50 border border-yellow-100 p-6 rounded-xl">
      <h4 class="font-bold text-yellow-800 mb-2 flex items-center">选择建议</h4>
      <ul class="text-sm text-yellow-700 space-y-3">
        <li>
          <strong>如果你是第一次使用：</strong> 优先从 Rakuten 开始，流程最标准，客服和教程都更成熟。
        </li>
        <li>
          <strong>如果你更在意返利率：</strong> TopCashback 往往会给出更高的返利比例，但使用习惯会稍有不同。
        </li>
        <li>
          <strong>如果你只想自动找券：</strong> Honey 更适合做浏览器插件和下单前自动比价。
        </li>
      </ul>
    </div>
  </div>
</BaseLayout>
