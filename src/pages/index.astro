---
import BaseLayout from '../layouts/BaseLayout.astro';
import PlatformCard from '../components/platform/PlatformCard.astro';
import ArticleCard from '../components/article/ArticleCard.astro';
import FAQAccordion from '../components/common/FAQAccordion.astro';

// 动态获取 guides 文件夹下的所有 markdown 文章
import { getCollection } from 'astro:content';
const allGuides = await getCollection('guides');
---

<BaseLayout title="首页">
    <section class="py-20 bg-gray-50 text-center px-4">
        <h1 class="text-4xl md:text-5xl font-extrabold text-gray-900 mb-6 tracking-tight">海外华人返利省钱指南</h1>
        <p class="text-lg text-gray-600 mb-8 max-w-2xl mx-auto leading-relaxed">
            用中文看懂 Rakuten、TopCashback、Honey 等返利平台怎么用。<br class="hidden md:block" />不夸大收益，客观拆解注册、购物、提现流程与避坑指南。
        </p>
        <div class="flex flex-col sm:flex-row justify-center gap-4">
            <a href="/guides/rakuten-guide" class="bg-blue-600 text-white px-8 py-3 rounded-lg font-medium hover:bg-blue-700 transition-colors">
                查看 Rakuten 新手教程
            </a>
            <a href="/compare" class="bg-white text-gray-700 border border-gray-300 px-8 py-3 rounded-lg font-medium hover:bg-gray-50 transition-colors">
                打开平台对比表
            </a>
        </div>
        <p class="text-xs text-gray-400 mt-6">
            透明说明：本站可能包含推荐链接，规则以官方页面为准。
        </p>
    </section>

    <div class="container mx-auto px-4 py-12 max-w-5xl">
        <section class="grid md:grid-cols-2 gap-6 mb-16">
            <div class="bg-green-50 rounded-xl p-6 border border-green-100">
                <h3 class="font-bold text-green-800 mb-3 flex items-center">✅ 适合人群</h3>
                <ul class="text-sm text-green-700 space-y-2">
                    <li>刚到海外，准备开始网购的新手</li>
                    <li>想比较不同平台差异的用户</li>
                    <li>愿意按步骤操作，确保返利追踪成功的用户</li>
                </ul>
            </div>
            <div class="bg-gray-50 rounded-xl p-6 border border-gray-200">
                <h3 class="font-bold text-gray-700 mb-3 flex items-center">❌ 不适合人群</h3>
                <ul class="text-sm text-gray-600 space-y-2">
                    <li>期待“注册即提现”、追求一夜暴富的人</li>
                    <li>不愿仔细看平台规则、不常网购的人</li>
                    <li>缺乏耐心等待商家确认订单周期的人</li>
                </ul>
            </div>
        </section>

        <section class="mb-16">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">常用平台快速了解</h2>
            <div class="grid md:grid-cols-3 gap-6">
                <PlatformCard 
                    name="Rakuten" 
                    positioning="美国最知名的返利网站，界面友好，客服响应快。" 
                    badge="最适合新手" 
                    link="/guides/rakuten-guide" 
                />
                <PlatformCard 
                    name="TopCashback" 
                    positioning="主打将 100% 佣金返给用户，很多时候返利率更高。" 
                    badge="高返利率" 
                    link="/guides/topcashback-guide" 
                />
                <PlatformCard 
                    name="PayPal Honey" 
                    positioning="浏览器插件，结账时自动帮你找优惠码，省去搜券烦恼。" 
                    badge="自动找券" 
                    link="/guides" 
                />
            </div>
        </section>

        <section class="mb-16">
            <div class="flex justify-between items-end mb-6">
                <h2 class="text-2xl font-bold text-gray-900">新手教程</h2>
                <a href="/guides" class="text-blue-600 hover:underline text-sm font-medium">查看全部 →</a>
            </div>
            <div class="grid md:grid-cols-2 gap-6">
                {allGuides.map((guide) => (
                    <ArticleCard 
                        title={guide.data.title}
                        description={guide.data.description}
                        lastUpdated={guide.data.lastUpdated}
                        slug={guide.id}
                    />
                ))}
            </div>
        </section>

        <section class="max-w-3xl mx-auto mb-10">
            <h2 class="text-2xl font-bold text-center text-gray-900 mb-8">常见问题</h2>
            <div class="bg-white border border-gray-200 rounded-xl px-6">
                <FAQAccordion 
                    question="返利平台为什么会给钱？是不是骗局？" 
                    answer="不是骗局。这是典型的“联盟营销”。商家为了获得客流，会付佣金给返利平台；返利平台为了吸引你使用，就把部分佣金分给你。这是一种三方共赢的商业模式。"
                />
                <FAQAccordion 
                    question="为什么我用了返利网却没有到账？" 
                    answer="常见原因包括：使用了广告拦截插件（如 AdBlock）、中途关闭了浏览器、使用了非平台提供的优惠码、或者购买了不在返利范围内的商品（如礼品卡）。"
                />
                <FAQAccordion 
                    question="推荐奖励是注册了马上就能提现吗？" 
                    answer="绝大多数情况下不是。平台通常要求你在规定时间（如 90 天内）通过他们去商家完成一笔或多笔“合格消费”（达到一定金额），且订单确认不退货后，奖励才会生效。"
                />
            </div>
        </section>
    </div>
</BaseLayout>
