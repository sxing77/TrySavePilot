---
interface Props {
    title: string;
    description: string;
    lastUpdated: string;
    slug: string;
}

const { title, description, lastUpdated, slug } = Astro.props;
---

<a href={`/guides/${slug}`} class="block group h-full">
    <article class="border border-gray-100 rounded-xl p-6 bg-white hover:border-blue-200 transition-colors h-full flex flex-col">
        <div class="text-xs text-gray-400 mb-2">更新于 {lastUpdated}</div>
        <h3 class="text-lg font-bold text-gray-900 group-hover:text-blue-600 mb-2">{title}</h3>
        <p class="text-gray-600 text-sm flex-grow">{description}</p>
    </article>
</a>