---
import '../styles/global.css';
import SEOMeta from '../components/common/SEOMeta.astro';
interface Props {
	title: string;
	description?: string;
}

const { title, description = "海外华人返利省钱指南 - 中文看懂 Rakuten, TopCashback, Honey" } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="sitemap" href="/sitemap-index.xml" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | 海外华人返利指南</title>
		<meta name="description" content={description} />
	</head>
	<body class="bg-white text-gray-900 flex flex-col min-h-screen">
		<header class="border-b border-gray-100 py-4">
			<nav class="container mx-auto px-4 flex justify-between items-center">
				<a href="/" class="text-xl font-bold text-blue-600">返利指南</a>
				<div class="space-x-6 hidden md:flex">
					<a href="/compare" class="hover:text-blue-600">平台对比</a>
					<a href="/guides" class="hover:text-blue-600">新手教程</a>
					<a href="/faq" class="hover:text-blue-600">常见问题</a>
				</div>
			</nav>
		</header>

		<main class="flex-grow">
			<slot />
		</main>

		<footer class="bg-gray-50 border-t border-gray-200 py-10 mt-20">
			<div class="container mx-auto px-4 text-center">
				<p class="text-sm text-gray-500 mb-4">
					说明：本站为个人整理的中文指南，非各返利平台官方网站。内容包含推荐链接，规则以官方页面为准。
				</p>
				<p class="text-xs text-gray-400">
					&copy; 2026 海外华人返利省钱网站. All Rights Reserved.
				</p>
			</div>
		</footer>
	</body>
</html>
